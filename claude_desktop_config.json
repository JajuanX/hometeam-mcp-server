{
  "mcpServers": {
    "hometeam-remote": {
      "transport": {
        "type": "sse",
        "url": "https://mcp.thehometeam.io/sse"
      }
    },
    "hometeam-local": {
      "command": "node",
      "args": ["/absolute/path/to/mcp-server/server.js"],
      "env": {
        "MONGO_URI": "mongodb://localhost:27017/hometeam"
      }
    }
  }
}
